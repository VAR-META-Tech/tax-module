# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=taxmodule
DB_PASSWORD=secret
DB_NAME=tax_module
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Third Party Invoice Service
THIRD_PARTY_BASE_URL=https://api-vinvoice.viettel.vn/services/einvoiceapplication/api
THIRD_PARTY_AUTH_URL=https://api-vinvoice.viettel.vn/auth/login
THIRD_PARTY_CREATE_PATH=/InvoiceAPI/InvoiceWS/createInvoice
THIRD_PARTY_QUERY_PATH=/InvoiceAPI/InvoiceWS/searchInvoiceByTransactionUuid
THIRD_PARTY_REPORT_TO_AUTHORITY_PATH=/InvoiceAPI/InvoiceWS/sendInvoiceByTransactionUuid
THIRD_PARTY_GET_FILE_PATH=/InvoiceAPI/InvoiceUtilsWS/getInvoiceRepresentationFile
THIRD_PARTY_SUPPLIER_CODE=                  # e.g. 0100109106-507
THIRD_PARTY_USERNAME=                       # e.g. 0100109106-507
THIRD_PARTY_PASSWORD=                       # from Viettel portal
THIRD_PARTY_API_KEY=                        # reserved — leave empty for Viettel
THIRD_PARTY_TIMEOUT=95s                     # Viettel recommends >= 90s
THIRD_PARTY_TEMPLATE_CODE=                  # e.g. 1/770
THIRD_PARTY_INVOICE_SERIES=                 # e.g. K23TXM
THIRD_PARTY_INVOICE_TYPE=1                  # 1-6 per TT78                  

# Provider
DEFAULT_PROVIDER=viettel             # "viettel" or "misa"

# MISA MeInvoice
MISA_BASE_URL=https://api.meinvoice.vn/api/integration
MISA_APP_ID=                        # from MISA portal
MISA_TAX_CODE=                      # seller tax code
MISA_USERNAME=                      # MISA login username
MISA_PASSWORD=                      # MISA login password
MISA_INVOICE_WITH_CODE=true         # true = invoice with authority code (loại có mã)
MISA_INVOICE_CALCU=false            # true = invoice from cash register machine
MISA_SIGN_TYPE=2                    # 2=HSM with CKS, 5=HSM without CKS, 1=USB/file
MISA_TIMEOUT=30s

# Worker
WORKER_POOL_SIZE=10
WORKER_QUEUE_SIZE=100
WORKER_POLL_INTERVAL=60s   
WORKER_MAX_RETRIES=5

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Seller Information
SELLER_LEGAL_NAME="CÔNG TY DEMO"
SELLER_TAX_CODE="0100109106"
SELLER_ADDRESS="123 Demo Street, Ha Noi"
SELLER_PHONE="0901234567"
SELLER_EMAIL="demo@example.com"
SELLER_BANK_NAME="Vietcombank"
SELLER_BANK_ACCOUNT="123456789"
