# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=taxmodule
DB_PASSWORD=secret
DB_NAME=tax_module
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Third Party Invoice Service
THIRD_PARTY_BASE_URL=http://localhost:9090
THIRD_PARTY_CREATE_PATH=/v1/invoices
THIRD_PARTY_QUERY_PATH=/v1/invoices/status
THIRD_PARTY_API_KEY=your-api-key
THIRD_PARTY_TIMEOUT=30s

# Worker
WORKER_POOL_SIZE=10
WORKER_QUEUE_SIZE=100
WORKER_POLL_INTERVAL=30s
WORKER_MAX_RETRIES=5

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
